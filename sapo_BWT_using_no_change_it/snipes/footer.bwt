						{%comment%}
						<p class="adr"><b>MST:</b> 8080980349-001</p>
						
						{%if settings.footer_address != null and settings.footer_address != ''%}
						<p class="adr"><b>{{settings.contact_add}} </b>{{settings.footer_address}}</p>
						{%else%}
						<p class="adr"><b>{{settings.contact_add}} </b>{{store.address}}</p>
						{%endif%}
						<p class="adr"><b>Kho hàng:</b> Linh Trung, P. Linh Trung, TP. Thủ Đức</p>
						{%if settings.footer_email != null and settings.footer_email != ''%}
						<p><b>Email: </b><a href="mailto:{{settings.footer_email}}" title="{{settings.footer_email}}">{{settings.footer_email}}</a></p>
						{%else%}
						<p><b>Email: </b><a href="mailto:{{store.customer_email}}" title="{{store.customer_email}}">{{store.customer_email}}</a></p>
						{%endif%}
						{%if settings.footer_phone != null and settings.footer_phone != ''%}
						<p><b>Hotline: </b><a href="tel:{{settings.footer_phone | remove: ' ' | remove: '.'}}" title="{{settings.footer_phone}}">{{settings.footer_phone}}</a></p>
						{%else%}
						<p><b>Hotline: </b><a href="tel:{{store.phone_number}}" title="{{store.phone_number}}">{{store.phone_number}}</a></p>
						{%endif%}
						{%if settings.mst != null and settings.mst != ''%}
						<p>{{settings.mst}}</p>
						{%endif%}
						{%endcomment%}
					</address>
				</div>
			{%endcomment%}	
				
				{%comment%} COT CHINH SACH
				<div class="col-xl-3 col-lg-3 col-md-6 col-sm-6 col-12 footer-left">
