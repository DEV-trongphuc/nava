				<style>
.footer-left .content ul {
  list-style: none; /* Xóa dấu đầu dòng mặc định */
  padding: 0; /* Xóa padding mặc định */
  margin: 0; /* Xóa margin mặc định */
  display: flex; /* Sắp xếp các thẻ li theo hàng ngang */
  align-items: center; /* Căn giữa theo chiều dọc */
  flex-wrap: wrap; /* Cho phép các thẻ li tự động xuống hàng */
}

.footer-left .content ul li {
  margin-right: 5px; /* Giảm khoảng cách giữa các thẻ li */
  margin-bottom: 5px; /* Khoảng cách dưới mỗi thẻ li khi xuống hàng */
  font-size: 80%; /* Giữ kích thước chữ 75% */
}

.footer-left .content ul li:not(:last-child)::after {
  content: "/"; /* Thêm dấu / sau mỗi li, trừ li cuối cùng */
  margin-left: 0px; /* Giảm khoảng cách bên trái của dấu / */
  color: #000; /* Màu của dấu /, có thể thay đổi */
}

.footer-left .content ul li a {
  text-decoration: none; /* Xóa gạch chân của liên kết */
  color: #000; /* Màu chữ, có thể thay đổi */
}

.footer-left .content ul li a:hover {
  color: #007bff; /* Màu khi hover, có thể thay đổi */
}

.footer-left .content {
  width: 100%; /* Đảm bảo container có đủ không gian */
}
</style>
