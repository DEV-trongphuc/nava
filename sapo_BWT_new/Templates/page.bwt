{% include 'breadcrumb' %}
<div class="com_info">
	<div class="container mt-3 mb-3">
		<div class="rounded-10 p-3 p-md-4 bg-white col-main page-title">
			<h1 class="font-weight-bold pt-2 pt-lg-0 mt-0 mb-3 page_name">
				{{page.title}}
			</h1>
			<div class="rte m-auto bg-white d-block text-justify">
				{{ page.content | default: settings.other_updating }}
			</div>
		</div>
	</div>
</div>
