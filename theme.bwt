    <!DOCTYPE html>
    <html lang="vi">
        <head> 
    <meta name="google-site-verification" content="8m9SdTZclMsrpstXktnwKHPsJKygRQmVT-xc0TUrQeU" />
            <meta  http-equiv="content-Type" content="text/html; charset=utf-8"/>
            <meta name="theme-color" content="{{settings.main_color}}">
            <meta  http-equiv="Content-Security-Policy" content="block-all-mixed-content">
            <link rel="canonical" href="{{ canonical_url }}"/>
            <meta name='revisit-after' content='2 days' />
            <link rel="preconnect" href="{{ canonical_url }}">
            <link rel="preconnect" href="https://bizweb.dktcdn.net" crossorigin>
            <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=2.0, user-scalable=0">			
            <title>{%include 'title_sn'%}</title>
            <!-- ================= Page description ================== -->
            {%- if page_description != "" -%}
            <meta name="description" content="{{ page_description | strip_html | remove: '"' }}">
            {%- endif -%}
            <!-- ================= Meta ================== -->
            {%if template contains 'index'%}{%if settings.home_page_keywords != '' and settings.home_page_keywords != null%}<meta name="keywords" content="{{settings.home_page_keywords}}"/>{%else%}<meta name="keywords" content="{{store.name}}, {{store.domain}}"/>{%endif%}{%elsif template contains 'product'%}<meta name="keywords" content="{{product.name}}, {%for collection in product.collections%}{{collection.name}}, {%endfor%}{%if product.tags.size > 0%}{% for tag in product.tags %}{{tag}}, {%endfor%}{%endif%}{{store.name}}, {{store.domain}}"/>{%elsif template contains 'collection'%}<meta name="keywords" content="{{collection.name }}, {{store.name}}, {{store.domain}}"/>{%elsif template contains 'blog'%}<meta name="keywords" content="{{blog.name }}, {{store.name}}, {{store.domain}}"/>{%elsif template contains 'article'%}<meta name="keywords" content="{{article.title}}, {{blog.name}}, {%if article.tags.size > 0%}{% for tag in article.tags %}{{tag}}, {%endfor%}{%endif%} {{store.name}}, {{store.domain}}"/>{%else%}<meta name="keywords" content="{{page_title}}, {{store.name}}, {{store.domain}}"/>{%endif%}		
            <meta name="robots" content="noodp,index,follow" />
            <link rel="shortcut icon" href="{{ 'favicon.png' | asset_url }}" type="image/x-icon" />  
            <link rel="preload" href="{{ 'logo.png' | asset_url | img_url: 'compact' }}" as="image" media="(min-width: 992px)" />
            {%- include 'fb-open-graph-tags' -%}
            <link rel="dns-prefetch" href="https://fonts.googleapis.com">
            <link rel="dns-prefetch" href="https://fonts.gstatic.com">
            <link rel="dns-prefetch" href="https://bizweb.dktcdn.net">
            <link rel="dns-prefetch" href="https://cdn.jsdelivr.net">
            <link rel="dns-prefetch" href="https://{{store.domain}}">
            <link rel="preload" as="image" href="{{'slide-img1.png' | asset_url | img_url: 'large'}}" media="screen and (max-width: 480px)">
            <link rel="preload" as="image" href="{{'slide-img2.png' | asset_url | img_url: 'large'}}" media="screen and (max-width: 480px)">
            {%-include 'head_styles'-%}
            {%-if template contains 'addresses'-%}
            <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.slim.min.js" integrity="sha512-6ORWJX/LrnSjBzwefdNUyLCMTIsGoNP6NftMy2UAm1JBm6PRZCO1d7OHBStWpVFZLO+RerTvqX/Z9mBFfCJZ4A==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
            <link rel="preload" as="script" href="{{ 'boostrap_min.js' | asset_url }}" />
            {{ 'boostrap_min.js' | asset_url | script_tag }} 
            {%-else-%}
            {%-if settings.use_sapo_app-%}
            <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js" integrity="sha512-894YE6QWD5I59HgZOGReFYm4dnWc1Qt5NtvYSaNcOP+u1T9qYdvdihz0PPSiiqn/+/3e7Jo4EaG7TubfWGUrMQ==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
            {{ 'api.jquery.js' | bizweb_asset_url | script_tag }}
            {%-else-%}
            <link rel="preload" as="script" href="{{ 'cash.min.js' | asset_url }}" />
            <script src="{{'cash.min.js' | asset_url}}"></script>
            {%-endif-%}
            {%-endif-%}
            <link rel="preload" as="script" href="{{ 'axios.min.js' | asset_url }}" />
            {{ 'axios.min.js'  | asset_url | script_tag }}

            {%- if template contains 'index' -%}
            <!-- Google Fonts Optimized -->
            <link href="https://fonts.googleapis.com/css2?family=Fira+Mono:wght@400;500&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
            <!-- Phosphor Icons -->
            <script src="https://unpkg.com/@phosphor-icons/web" defer></script>
            <!-- Custom CSS -->
            <link rel="stylesheet" href="https://nava-one.vercel.app/assets/style.css?v=20260429_v2">
            <!-- Theme Script for FOUC -->
            <script>
                const savedTheme = localStorage.getItem('nava-theme');
                if (savedTheme === 'dark') {
                    document.documentElement.setAttribute('data-theme', 'dark');
                }
            </script>
            {%- endif -%}

            {{ content_for_header }}

            {%comment%}{%endcomment%}
            {%if template contains 'customers'%}{{ 'custom.scss.css' | asset_url | stylesheet_tag }}{{ 'common.js' | bizweb_asset_url | script_tag }}{{ 'bizweb-api.js' | bizweb_asset_url | script_tag }}{{ 'customer.js'  | bizweb_asset_url | script_tag }}{%endif%}
            {%-if template contains 'product'-%}
            <script rel="dns-prefetch">var ProductReviewsAppUtil=ProductReviewsAppUtil || {};{% if customer %}ProductReviewsAppUtil.customer={id: '{{customer.id}}',name: '{{customer.name}}',email: '{{customer.email}}', phone: '{{customer.phone}}'};{% endif %}ProductReviewsAppUtil.store={name: '{{store.name}}'};</script>
            {%-endif-%}
            {%-include 'schema'-%}
            <style>
                img {
                    -webkit-user-drag: none;
                    user-drag: none;
                    -webkit-touch-callout: none;
                }
                #marquee-container {
                    width: 100%;
                    overflow: hidden;
                    white-space: nowrap;
                    box-sizing: border-box;
                    position: relative;
                    height: 40px;

                }

                #marquee-text {
                    position: absolute;
                    white-space: nowrap;
                    will-change: transform;
                }
            </style>
            {%comment%}	<!-- Google tag (gtag.js) --> Script cua Bao
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-KPV4HGYRVZ"></script>
    <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-KPV4HGYRVZ');
    </script>
            {%endcomment%}
            
            
            {%comment%} ADS {%endcomment%}
            <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-PVC2Z8LJ');</script>
    <!-- End Google Tag Manager -->
            
            
        </head>
        <body id="body_m" {% if customer %}class="customer-logged-in"{% endif %} >
            
            
            {%comment%} hieu ung tuyet roi - DAT
            {{ 'snow-effect.js' | asset_url | script_tag }}
            
            {{ 'hoamai.js' | asset_url | script_tag }}{%endcomment%}
            
            <div class="page-body">
                <div class="hidden-md hidden-lg opacity_menu"></div>
                <div class="opacity_filter"></div>
                <div id="body_overlay" class="position-fixed d-none"></div>
                <div class="w-100 clearfix">
                    {%- unless template contains 'index' -%}
                    {%- include 'header' -%}  
                    {%- endunless -%}
                    <div class="col-right position-relative">
                        <div class="contentWarp {%if template == 'page.arthor'%}pb-5{%endif%}">
                            {{ content_for_layout }}
                        </div>
                        {%- unless template contains 'index' -%}
                        {%- include 'footer' -%}
                        {%- endunless -%}
                    </div>
                </div>
                <div onclick="scrollToTop(100);" class="back_top d-flex position-fixed justify-content-center align-items-center">
                    <img alt="{{settings.other_backtotop}}" src="{{'to-top-arrow2.png' | asset_url}}">
                </div>
                {%-if template != 'product'-%}
                {%-include 'mew_mobi_bar'-%}
                {%-endif-%}
                <div class="toast-container"></div>
                {%-include 'footer_scripts'-%}
                {%-include 'svg-cache'-%}
                <link rel="preload" as="style"  href="{{ 'fonts.css' | asset_url }}" type="text/css">
                {{ 'fonts.css' | asset_url | stylesheet_tag }}
            </div>
            {%-if settings.ena_popup_news-%}
            {%include 'popup_news'%}
            {%-endif-%}
            {%if settings.ena_isocial_bubble%}
            {%include 'isocial_bubble'%}
            {%endif%}
            {%comment%} ADS {%endcomment%}
            <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-PVC2Z8LJ"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
            
        </body>
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                document.querySelectorAll("img").forEach(function (img) {
                    if (!img.hasAttribute("alt") || img.alt.trim() === "minipc navastore maytinh #miniPC phukien egpu Minisforum MINISFORUM eGPU Laptop NavaStore") {
                        // Gán alt dựa trên tên file ảnh hoặc tiêu đề trang
                        let fileName = img.src.split('/').pop().split('.')[0];
                        img.alt = fileName.replace(/[-_]/g, ' ');
                    }
                });
            });
        </script>
        {%comment%}
        <script>
            // Chặn menu chuột phải trên tất cả các thẻ <img>
            document.addEventListener("DOMContentLoaded", function () {
                const images = document.querySelectorAll("img");
                images.forEach(function (img) {
                    img.addEventListener("contextmenu", function (e) {
                        e.preventDefault(); // Ngăn hiện menu chuột phải
                    });
                });
            });
        </script>
        {%endcomment%}

        

    </html>